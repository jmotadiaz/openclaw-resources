<file path="src/strategies/FlightScraperStrategy.ts">
export interface ScoutParams {
  origin: string;
  destination: string;
  month: string;
  session_id: string;
  dbPath: string;
}

export interface SearchParams {
  origin: string;
  destination: string;
  exact_date: string;
  return_date?: string;
  pax: number;
  session_id: string;
  dbPath: string;
}

export interface ScraperResult {
  status: string;
  summary?: string;
